{
  "$schema": "../schemas/task-registry.schema.json",
  "schemaVersion": 1,
  "categories": {
    "validate": "Deterministic validation, lint, policy, and security gates.",
    "release": "Candidate build, promotion, reconciliation, and release proof operations.",
    "evidence": "Generated facts, compatibility records, inventories, and quality evidence.",
    "docs": "Documentation synchronization and documentation-specific generation.",
    "migration": "Scaffolding, normalization, and versioned contract migrations.",
    "benchmark": "Tests, coverage, simulations, demos, mutations, and live evaluation.",
    "maintenance": "Diagnostics, repository administration, and reusable script libraries."
  },
  "scriptRules": [
    { "pattern": "^scripts/lib/", "category": "maintenance" },
    { "pattern": "^scripts/(?:validate-|lint-|scan-|verify-agents\\.)", "category": "validate" },
    { "pattern": "^scripts/(?:build-(?:candidate|release)|extract-release|generate-release|prepare-release|reconcile-github-release|release-orchestrator|verify-(?:independent-release|release-promotion|stable-install))", "category": "release" },
    { "pattern": "^scripts/generate-(?:surface-inventory|diagnostics-docs|command-docs|doc-governance)", "category": "docs" },
    { "pattern": "^scripts/(?:migrate-|normalize-|scaffold)", "category": "migration" },
    { "pattern": "^scripts/(?:evaluate-|run-(?:critical|live|node-tests|real-task|test-coverage)|demo-)", "category": "benchmark" },
    { "pattern": "^scripts/(?:audit-dependenc(?:ies|y-licenses)|collect-github-metrics|generate-)", "category": "evidence" },
    { "pattern": "^scripts/(?:doctor|print-github-security-settings|profile-validation|sync-github-labels)", "category": "maintenance" }
  ],
  "npmScriptRules": [
    { "pattern": "^(?:validate|lint|scan|ci:|check|typecheck$)", "category": "validate" },
    { "pattern": "^release:", "category": "release" },
    { "pattern": "^generate:(?:command-docs|doc-governance|diagnostics-docs)", "category": "docs" },
    { "pattern": "^(?:audit:|generate:)", "category": "evidence" },
    { "pattern": "^(?:test|eval:|demo:)", "category": "benchmark" },
    { "pattern": "^(?:scaffold:|normalize:|migrate:)", "category": "migration" },
    { "pattern": "^(?:doctor$|llmf$|sync:)", "category": "maintenance" }
  ],
  "generatedOutputs": [
    "docs/operations/maintainers/task-catalog.generated.md"
  ]
}
