{
  "$schema": "../schemas/workflow-product.schema.json",
  "schemaVersion": 2,
  "pluginNamespace": "nova-plugin",
  "expectedWorkflowCount": 21,
  "stages": ["explore", "plan", "review", "implement", "finalize"],
  "primaryEntrypoints": ["route", "explore", "produce-plan", "review", "implement-plan", "finalize-work"],
  "runtimeCompatibility": { "claude-code": "2.1.205" },
  "compatibilityAliasPolicy": {
    "status": "evidence-gated",
    "removalRequires": [
      "real-benchmark-evidence",
      "plugin-major-release",
      "governed-release-decision",
      "migration-documentation"
    ]
  },
  "automaticRouting": {
    "identity": "canonical-surface-plus-variant-parameters",
    "canonicalTargets": [
      "explore",
      "finalize-work",
      "implement-plan",
      "produce-plan",
      "review",
      "route"
    ],
    "compatibilityAliases": "excluded"
  },
  "adapterDefinitions": ["adapters/claude.json", "adapters/codex.json", "adapters/generic.json"],
  "agents": ["architect", "builder", "orchestrator", "publisher", "reviewer", "verifier"],
  "packs": ["dependency", "docs", "frontend", "java", "marketplace", "mcp", "release", "security"],
  "tools": ["Read", "Glob", "Grep", "Edit", "Write", "Bash", "NotebookEdit"]
}
