{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/lliangcol/llm-plugins-fusion/main/schemas/dependency-audit-evidence.schema.json",
  "type": "object", "additionalProperties": false,
  "required": ["schemaVersion", "status", "reasonCode", "source", "lockDigest", "scope", "vulnerabilities", "findings", "exceptionsApplied", "policyViolations"],
  "properties": {
    "schemaVersion": { "const": 1 }, "status": { "enum": ["passed", "failed", "blocked"] },
    "reasonCode": { "type": ["string", "null"] }, "source": { "const": "npm-audit" },
    "lockDigest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "scope": { "type": "object", "additionalProperties": false, "required": ["maintenanceDevOnly", "runtimeDistributed"], "properties": { "maintenanceDevOnly": { "const": true }, "runtimeDistributed": { "const": false } } },
    "vulnerabilities": { "type": "object", "additionalProperties": false, "required": ["info", "low", "moderate", "high", "critical", "total"], "properties": { "info": { "type": "integer", "minimum": 0 }, "low": { "type": "integer", "minimum": 0 }, "moderate": { "type": "integer", "minimum": 0 }, "high": { "type": "integer", "minimum": 0 }, "critical": { "type": "integer", "minimum": 0 }, "total": { "type": "integer", "minimum": 0 } } },
    "findings": { "type": "array", "items": { "type": "object", "additionalProperties": false, "required": ["dependency", "severity", "isDirect", "advisories"], "properties": { "dependency": { "type": "string", "minLength": 1 }, "severity": { "enum": ["info", "low", "moderate", "high", "critical"] }, "isDirect": { "type": "boolean" }, "advisories": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } } } } },
    "exceptionsApplied": { "type": "array", "items": { "type": "object", "additionalProperties": false, "required": ["advisory", "scope", "dependencies"], "properties": { "advisory": { "type": "string", "minLength": 1 }, "scope": { "enum": ["direct", "transitive", "dev-only", "runtime-distributed", "archive-excluded"] }, "dependencies": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } } } } },
    "policyViolations": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
  }
}
