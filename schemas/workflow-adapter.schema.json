{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/lliangcol/llm-plugins-fusion/main/schemas/workflow-adapter.schema.json",
  "title": "Assistant adapter definition",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "enforcement", "declaredLevel", "maximumSupportedLevel", "invocation", "evidenceRequiredFor"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "enum": [1, 2] },
    "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "enforcement": { "enum": ["native-and-hook", "adapter", "advisory", "unsupported"] },
    "declaredLevel": { "enum": ["L1", "L2", "L3", "L4"] },
    "maximumSupportedLevel": { "enum": ["L1", "L2", "L3", "L4"] },
    "invocation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "prefix"],
      "properties": {
        "kind": { "enum": ["namespaced-command", "repository-adapter", "contract-manifest"] },
        "prefix": { "type": "string" }
      }
    },
    "evidenceRequiredFor": { "type": "array", "uniqueItems": true, "items": { "enum": ["L2", "L3", "L4"] } },
    "protocolVersions": {
      "type": "object", "additionalProperties": false,
      "required": ["workflow", "runtime", "adapter"],
      "properties": { "workflow": { "type": "string", "pattern": "^6\\." }, "runtime": { "type": "string", "pattern": "^4\\." }, "adapter": { "type": "string", "pattern": "^3\\." } }
    },
    "contractEnforcement": {
      "type": "object", "additionalProperties": false,
      "required": ["inputs", "approval", "output", "effects", "fallback"],
      "properties": {
        "inputs": { "enum": ["native", "adapter", "advisory", "unsupported"] },
        "approval": { "enum": ["native", "hook", "adapter", "advisory", "unsupported"] },
        "output": { "enum": ["native", "adapter", "advisory", "unsupported"] },
        "effects": { "enum": ["native-and-hook", "adapter", "advisory", "unsupported"] },
        "fallback": { "enum": ["fail-closed", "report-unsupported"] }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "schemaVersion": { "const": 1 } }, "required": ["schemaVersion"] },
      "then": { "properties": { "protocolVersions": false, "contractEnforcement": false } }
    },
    {
      "if": { "properties": { "schemaVersion": { "const": 2 } }, "required": ["schemaVersion"] },
      "then": { "required": ["protocolVersions", "contractEnforcement"] }
    },
    {
      "oneOf": [
        { "type": "object", "required": ["declaredLevel", "maximumSupportedLevel", "evidenceRequiredFor"], "properties": { "declaredLevel": { "const": "L1" }, "maximumSupportedLevel": { "const": "L1" }, "evidenceRequiredFor": { "const": [] } } },
        { "type": "object", "required": ["declaredLevel", "maximumSupportedLevel", "evidenceRequiredFor"], "properties": { "declaredLevel": { "const": "L1" }, "maximumSupportedLevel": { "const": "L2" }, "evidenceRequiredFor": { "const": ["L2"] } } },
        { "type": "object", "required": ["declaredLevel", "maximumSupportedLevel", "evidenceRequiredFor"], "properties": { "declaredLevel": { "const": "L1" }, "maximumSupportedLevel": { "const": "L3" }, "evidenceRequiredFor": { "const": ["L2", "L3"] } } },
        { "type": "object", "required": ["declaredLevel", "maximumSupportedLevel", "evidenceRequiredFor"], "properties": { "declaredLevel": { "const": "L1" }, "maximumSupportedLevel": { "const": "L4" }, "evidenceRequiredFor": { "const": ["L2", "L3", "L4"] } } },
        { "type": "object", "required": ["declaredLevel", "maximumSupportedLevel", "evidenceRequiredFor"], "properties": { "declaredLevel": { "const": "L2" }, "maximumSupportedLevel": { "const": "L2" }, "evidenceRequiredFor": { "const": [] } } },
        { "type": "object", "required": ["declaredLevel", "maximumSupportedLevel", "evidenceRequiredFor"], "properties": { "declaredLevel": { "const": "L2" }, "maximumSupportedLevel": { "const": "L3" }, "evidenceRequiredFor": { "const": ["L3"] } } },
        { "type": "object", "required": ["declaredLevel", "maximumSupportedLevel", "evidenceRequiredFor"], "properties": { "declaredLevel": { "const": "L2" }, "maximumSupportedLevel": { "const": "L4" }, "evidenceRequiredFor": { "const": ["L3", "L4"] } } },
        { "type": "object", "required": ["declaredLevel", "maximumSupportedLevel", "evidenceRequiredFor"], "properties": { "declaredLevel": { "const": "L3" }, "maximumSupportedLevel": { "const": "L3" }, "evidenceRequiredFor": { "const": [] } } },
        { "type": "object", "required": ["declaredLevel", "maximumSupportedLevel", "evidenceRequiredFor"], "properties": { "declaredLevel": { "const": "L3" }, "maximumSupportedLevel": { "const": "L4" }, "evidenceRequiredFor": { "const": ["L4"] } } },
        { "type": "object", "required": ["declaredLevel", "maximumSupportedLevel", "evidenceRequiredFor"], "properties": { "declaredLevel": { "const": "L4" }, "maximumSupportedLevel": { "const": "L4" }, "evidenceRequiredFor": { "const": [] } } }
      ]
    }
  ]
}
