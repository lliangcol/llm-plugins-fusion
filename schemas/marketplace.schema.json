{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/lliangcol/llm-plugins-fusion/schemas/marketplace.schema.json",
  "title": "Marketplace Registry",
  "description": "Schema for .claude-plugin/marketplace.json aligned with the Claude-compatible marketplace manifest. Repository-local custom metadata belongs in .claude-plugin/marketplace.metadata.json.",
  "type": "object",
  "required": ["name", "owner", "plugins"],
  "additionalProperties": true,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "email": { "type": "string", "format": "email" },
        "url": { "type": "string", "format": "uri" }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "description": { "type": "string" }
      }
    },
    "plugins": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "source", "version"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[a-z0-9](-?[a-z0-9])*$"
          },
          "source": {
            "oneOf": [
              {
                "type": "string",
                "minLength": 1,
                "description": "Relative path to plugin directory"
              },
              {
                "type": "object",
                "required": ["source"],
                "additionalProperties": true,
                "properties": {
                  "source": {
                    "type": "string",
                    "enum": ["local", "url", "git-subdir"]
                  },
                  "url": { "type": "string", "format": "uri" },
                  "path": { "type": "string" },
                  "ref": { "type": "string" },
                  "sha": { "type": "string" }
                }
              }
            ]
          },
          "version": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+$"
          },
          "author": {
            "type": "object",
            "required": ["name"],
            "additionalProperties": true,
            "properties": {
              "name": { "type": "string" },
              "email": { "type": "string", "format": "email" },
              "url": { "type": "string", "format": "uri" }
            }
          },
          "description": { "type": "string" },
          "category": {
            "type": "string",
            "enum": [
              "development",
              "productivity",
              "review",
              "testing",
              "documentation",
              "devops",
              "security",
              "data",
              "workflow",
              "other"
            ]
          },
          "homepage": { "type": "string", "format": "uri" },
          "repository": { "type": "string", "format": "uri" },
          "license": { "type": "string" },
          "tags": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "keywords": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "icon": { "type": "string" },
          "screenshots": {
            "type": "array",
            "items": { "type": "string" }
          },
          "checksum": { "type": "string" }
        }
      }
    }
  }
}
