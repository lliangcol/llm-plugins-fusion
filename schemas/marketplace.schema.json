{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/lliangcol/llm-plugins-fusion/schemas/marketplace.schema.json",
  "title": "Marketplace Registry",
  "description": "Schema for .claude-plugin/marketplace.json",
  "type": "object",
  "required": ["name", "owner", "plugins"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "description": {
          "type": "string"
        }
      }
    },
    "plugins": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "source", "version"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "type": "string",
            "minLength": 1,
            "description": "Relative path to plugin directory"
          },
          "version": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+$"
          },
          "author": {
            "type": "object",
            "required": ["name"],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string"
              }
            }
          },
          "description": {
            "type": "string"
          }
        }
      }
    }
  }
}
