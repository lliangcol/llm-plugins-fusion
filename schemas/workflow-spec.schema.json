{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/lliangcol/llm-plugins-fusion/main/schemas/workflow-spec.schema.json",
  "title": "Generic canonical workflow specification",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "contractVersions", "permissionProfiles", "workflows"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "enum": [5, 6] },
    "contractVersions": {
      "type": "object",
      "required": ["workflow", "runtime", "adapter"],
      "additionalProperties": false,
      "properties": {
        "workflow": { "type": "string", "pattern": "^[56]\\." },
        "runtime": { "type": "string", "pattern": "^[34]\\." },
        "adapter": { "type": "string", "pattern": "^[23]\\." },
        "framework": { "type": "string", "pattern": "^5\\." },
        "compatibilityProjection": { "type": "string", "pattern": "^5\\." }
      }
    },
    "permissionProfiles": {
      "type": "object"
    },
    "workflows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "stage", "ownerAgents", "recommendedPacks", "requiredInputs", "outputContract", "risk", "modelInvocable", "subagentSafe", "permissionProfile", "legacyAlias", "contractPath", "canonicalSurfaceId", "variantPreset", "compatibilityAlias"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "stage": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "ownerAgents": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } },
          "recommendedPacks": { "type": "array", "uniqueItems": true, "items": { "type": "string" } },
          "requiredInputs": { "type": "array", "uniqueItems": true, "items": { "type": "string" } },
          "outputContract": { "type": "string", "minLength": 1 },
          "risk": { "enum": ["none", "low", "medium", "high"] },
          "modelInvocable": { "type": "boolean" },
          "subagentSafe": { "type": "boolean" },
          "permissionProfile": { "type": "string" },
          "legacyAlias": { "type": "string" },
          "contractPath": { "type": "string" },
          "canonicalSurfaceId": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "variantPreset": { "type": "object" },
          "compatibilityAlias": { "type": "boolean" },
          "compatibility": { "type": "string" },
          "inputs": {
            "type": "array", "minItems": 1, "uniqueItems": true,
            "items": {
              "type": "object", "additionalProperties": false,
              "required": ["name", "type", "required"],
              "properties": {
                "name": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
                "type": { "enum": ["string", "enum", "boolean", "path", "artifact-reference", "review-reference", "approval"] },
                "required": { "type": "boolean" },
                "values": { "type": "array", "minItems": 1, "uniqueItems": true },
                "pathPolicy": {
                  "type": "object", "additionalProperties": false,
                  "required": ["root", "mustExist", "kind", "readable", "writable", "outsideRoot"],
                  "properties": {
                    "root": { "enum": ["workspace", "artifact-root"] }, "mustExist": { "type": "boolean" },
                    "kind": { "enum": ["file", "directory", "either"] }, "readable": { "type": "boolean" },
                    "writable": { "type": "boolean" }, "outsideRoot": { "enum": ["deny", "explicit-authorization"] }
                  }
                },
                "approvalPolicy": {
                  "type": "object", "additionalProperties": false,
                  "required": ["mustBeExplicit", "mayInfer", "scope"],
                  "properties": { "mustBeExplicit": { "const": true }, "mayInfer": { "const": false }, "scope": { "type": "string", "minLength": 1 }, "oneShot": { "type": "boolean" }, "expires": { "type": ["string", "null"] } }
                }
              }
            }
          },
          "effects": { "type": "array", "uniqueItems": true, "items": { "enum": ["workspace-read", "workspace-write", "artifact-write", "shell", "network", "credentials", "user-scope-mutation", "external-publish", "git-history-mutation"] } },
          "authorizationProfile": { "type": "string", "minLength": 1 },
          "enforcementRequirements": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
          "evidenceRequirements": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
          "compatibilityProjection": {
            "type": "object", "additionalProperties": false,
            "required": ["sourceVersion", "permissionProfile", "requiredInputs"],
            "properties": { "sourceVersion": { "const": 5 }, "permissionProfile": { "type": "string" }, "requiredInputs": { "type": "array", "uniqueItems": true, "items": { "type": "string" } } }
          },
          "runtimeRequirements": {
            "type": "object",
            "additionalProperties": false,
            "required": ["executables", "network", "credentials"],
            "properties": {
              "executables": {
                "type": "array",
                "uniqueItems": true,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["name", "required", "versionEvidence"],
                  "properties": {
                    "name": { "type": "string" },
                    "required": { "type": "boolean" },
                    "versionEvidence": { "enum": ["none", "versioned-evidence"] }
                  }
                }
              },
              "network": {
                "type": "object",
                "additionalProperties": false,
                "required": ["need", "purpose"],
                "properties": {
                  "need": { "enum": ["none", "optional", "required"] },
                  "purpose": { "type": "string" }
                }
              },
              "credentials": {
                "type": "object",
                "additionalProperties": false,
                "required": ["need", "source"],
                "properties": {
                  "need": { "enum": ["none", "optional", "required"] },
                  "source": { "enum": ["none", "assistant-owned-authentication", "consumer-owned-authentication"] }
                }
              }
            }
          }
        }
      }
    }
  },
  "allOf": [{ "if": { "properties": { "schemaVersion": { "const": 6 } } }, "then": { "properties": { "contractVersions": { "type": "object", "required": ["workflow", "runtime", "adapter", "framework", "compatibilityProjection"], "properties": { "workflow": {}, "runtime": {}, "adapter": {}, "framework": {}, "compatibilityProjection": {} } }, "workflows": { "type": "array", "items": { "type": "object", "required": ["inputs", "effects", "authorizationProfile", "enforcementRequirements", "evidenceRequirements", "compatibilityProjection"], "properties": { "inputs": {}, "effects": {}, "authorizationProfile": {}, "enforcementRequirements": {}, "evidenceRequirements": {}, "compatibilityProjection": {} } } } } } }]
}
