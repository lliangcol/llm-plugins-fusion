{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/lliangcol/llm-plugins-fusion/schemas/marketplace-metadata.schema.json",
  "title": "Marketplace Custom Metadata",
  "description": "Repository-local custom plugin metadata kept separate from the Claude-compatible marketplace manifest.",
  "type": "object",
  "required": ["plugins"],
  "additionalProperties": false,
  "properties": {
    "plugins": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "version",
          "trust-level",
          "risk-level",
          "deprecated",
          "last-updated",
          "maintainer",
          "compatibility",
          "review"
        ],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[a-z0-9](-?[a-z0-9])*$"
          },
          "version": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+$"
          },
          "trust-level": {
            "type": "string",
            "enum": ["official", "author-verified", "community", "experimental"]
          },
          "risk-level": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "deprecated": { "type": "boolean" },
          "last-updated": { "type": "string", "format": "date" },
          "maintainer": {
            "type": "object",
            "required": ["name"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "email": { "type": "string", "format": "email" },
              "url": { "type": "string", "format": "uri" }
            }
          },
          "compatibility": {
            "type": "object",
            "required": ["commands", "skills", "docs", "validation", "prerequisites"],
            "additionalProperties": false,
            "properties": {
              "commands": { "type": "string", "minLength": 1 },
              "skills": { "type": "string", "minLength": 1 },
              "docs": { "type": "string", "minLength": 1 },
              "validation": { "type": "string", "minLength": 1 },
              "prerequisites": { "type": "string", "minLength": 1 }
            }
          },
          "review": {
            "type": "object",
            "required": ["trustPolicy", "securityReview", "releaseHygiene"],
            "additionalProperties": false,
            "properties": {
              "trustPolicy": { "type": "string", "minLength": 1 },
              "securityReview": { "type": "string", "minLength": 1 },
              "releaseHygiene": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  }
}
