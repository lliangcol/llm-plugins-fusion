{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/lliangcol/llm-plugins-fusion/schemas/marketplace-metadata.schema.json",
  "title": "Marketplace Custom Metadata",
  "description": "Repository-local custom plugin metadata kept separate from the Claude-compatible marketplace manifest.",
  "type": "object",
  "required": ["plugins"],
  "additionalProperties": false,
  "properties": {
    "plugins": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "version", "trust-level", "risk-level", "deprecated", "last-updated"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[a-z0-9](-?[a-z0-9])*$"
          },
          "version": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+$"
          },
          "trust-level": {
            "type": "string",
            "enum": ["official", "author-verified", "community", "experimental"]
          },
          "risk-level": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "deprecated": { "type": "boolean" },
          "last-updated": { "type": "string", "format": "date" }
        }
      }
    }
  }
}
