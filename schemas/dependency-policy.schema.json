{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/lliangcol/llm-plugins-fusion/main/schemas/dependency-policy.schema.json",
  "title": "Dependency review policy",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "failOnSeverity", "deniedLicenses", "commentSummaryInPr", "auditExceptions", "licenseReviews", "distributedNodeRuntimeDependencies"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "failOnSeverity": { "enum": ["moderate", "high", "critical"] },
    "deniedLicenses": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9.+-]*$" }
    },
    "commentSummaryInPr": { "enum": ["never", "always", "on-failure"] },
    "distributedNodeRuntimeDependencies": { "const": false },
    "auditExceptions": { "type": "array", "items": { "type": "object", "additionalProperties": false, "required": ["advisory", "scope", "reason", "owner", "expires"], "properties": {
      "advisory": { "type": "string", "minLength": 1 }, "scope": { "enum": ["direct", "transitive", "dev-only", "runtime-distributed", "archive-excluded"] },
      "reason": { "type": "string", "minLength": 1 }, "owner": { "type": "string", "minLength": 1 }, "expires": { "type": "string", "format": "date" }
    } } },
    "licenseReviews": { "type": "array", "items": { "type": "object", "additionalProperties": false, "required": ["package", "version", "expression", "decision", "reason", "owner", "expires"], "properties": {
      "package": { "type": "string", "minLength": 1 }, "version": { "type": "string", "minLength": 1 }, "expression": { "type": ["string", "null"] },
      "decision": { "enum": ["allow", "deny", "select"] }, "selectedLicense": { "type": "string", "minLength": 1 },
      "reason": { "type": "string", "minLength": 1 }, "owner": { "type": "string", "minLength": 1 }, "expires": { "type": "string", "format": "date" }
    }, "allOf": [{ "if": { "properties": { "decision": { "const": "select" } }, "required": ["decision"] }, "then": { "properties": { "selectedLicense": { "type": "string", "minLength": 1 } }, "required": ["selectedLicense"] } }] } }
  }
}
