{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/lliangcol/llm-plugins-fusion/main/schemas/engineering-evidence.schema.json",
  "title": "Engineering evidence governance bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "criticalCoverage",
    "evidenceLevels",
    "platformEvidence",
    "validationPerformance"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "schemaVersion": {
      "const": 1
    },
    "criticalCoverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "baselineDate",
        "claimBoundary",
        "modules"
      ],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "baselineDate": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "claimBoundary": {
          "type": "string",
          "minLength": 1
        },
        "modules": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "lines",
              "branches",
              "functions"
            ],
            "properties": {
              "lines": {
                "type": "integer",
                "minimum": 0,
                "maximum": 100
              },
              "branches": {
                "type": "integer",
                "minimum": 0,
                "maximum": 100
              },
              "functions": {
                "type": "integer",
                "minimum": 0,
                "maximum": 100
              }
            }
          }
        }
      }
    },
    "evidenceLevels": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "levels",
        "sourceControlledStableProof",
        "dynamicEvidenceStorage",
        "forbiddenPayloads"
      ],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "levels": {
          "type": "array",
          "minItems": 6,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "name",
              "proves",
              "doesNotProve"
            ],
            "properties": {
              "id": {
                "enum": [
                  "E0",
                  "E1",
                  "E2",
                  "E3",
                  "E4",
                  "E5"
                ]
              },
              "name": {
                "type": "string",
                "minLength": 1
              },
              "proves": {
                "type": "string",
                "minLength": 1
              },
              "doesNotProve": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "sourceControlledStableProof": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "highestAcceptedLevel",
            "source"
          ],
          "properties": {
            "highestAcceptedLevel": {
              "enum": [
                "E0",
                "E1",
                "E2",
                "E3"
              ]
            },
            "source": {
              "const": "governance/stable-install-proof.json"
            }
          }
        },
        "dynamicEvidenceStorage": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "forbiddenPayloads": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "platformEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "tasks",
        "containerFallback"
      ],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "tasks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "classification",
              "localWindowsPath",
              "authoritativePath",
              "evidenceStrength",
              "reasonCode"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "classification": {
                "enum": [
                  "native-node",
                  "powershell-equivalent",
                  "container-candidate",
                  "bash-authoritative"
                ]
              },
              "localWindowsPath": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "authoritativePath": {
                "type": "string"
              },
              "evidenceStrength": {
                "enum": [
                  "authoritative",
                  "equivalent",
                  "partial",
                  "external"
                ]
              },
              "reasonCode": {
                "type": "string"
              }
            }
          }
        },
        "containerFallback": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "automatic",
            "enabled",
            "imageDigest",
            "network",
            "mount",
            "argv"
          ],
          "properties": {
            "automatic": {
              "const": false
            },
            "enabled": {
              "type": "boolean"
            },
            "imageDigest": {
              "type": [
                "string",
                "null"
              ]
            },
            "network": {
              "const": "none"
            },
            "mount": {
              "const": "read-only"
            },
            "argv": {
              "const": [
                "bash",
                "-n"
              ]
            }
          },
          "allOf": [
            {
              "if": {
                "properties": {
                  "enabled": {
                    "const": true
                  }
                },
                "required": [
                  "enabled"
                ]
              },
              "then": {
                "properties": {
                  "imageDigest": {
                    "type": "string",
                    "pattern": "^sha256:[a-f0-9]{64}$"
                  }
                }
              }
            },
            {
              "if": {
                "properties": {
                  "enabled": {
                    "const": false
                  }
                },
                "required": [
                  "enabled"
                ]
              },
              "then": {
                "properties": {
                  "imageDigest": {
                    "type": "null"
                  }
                }
              }
            }
          ]
        }
      }
    },
    "validationPerformance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "enforcement",
        "minimumStableSamples",
        "profiles",
        "legacyBudgets"
      ],
      "properties": {
        "schemaVersion": {
          "const": 2
        },
        "enforcement": {
          "const": "profile-required"
        },
        "minimumStableSamples": {
          "type": "integer",
          "minimum": 20
        },
        "profiles": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "platform",
              "arch",
              "nodeMajor",
              "runnerClass",
              "concurrency",
              "scenario",
              "sampleCount",
              "budgets",
              "owner",
              "reason",
              "regressionRisk"
            ],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "platform": {
                "enum": [
                  "windows",
                  "linux",
                  "macos"
                ]
              },
              "arch": {
                "enum": [
                  "x64",
                  "arm64"
                ]
              },
              "nodeMajor": {
                "type": "integer",
                "minimum": 22
              },
              "runnerClass": {
                "type": "string",
                "minLength": 1
              },
              "concurrency": {
                "type": "integer",
                "minimum": 1
              },
              "scenario": {
                "enum": [
                  "fresh-process-full-uncached",
                  "full-cache-warm",
                  "incremental-cache-warm"
                ]
              },
              "sampleCount": {
                "type": "integer",
                "minimum": 1
              },
              "budgets": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "elapsedWallMs",
                  "runtimeSmokeMs"
                ],
                "properties": {
                  "elapsedWallMs": {
                    "type": "integer",
                    "minimum": 1000
                  },
                  "runtimeSmokeMs": {
                    "type": "integer",
                    "minimum": 1000
                  }
                }
              },
              "owner": {
                "type": "string",
                "minLength": 1
              },
              "reason": {
                "type": "string",
                "minLength": 1
              },
              "regressionRisk": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "legacyBudgets": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "deprecated",
            "validateAllWallMs",
            "runtimeSmokeWallMs",
            "note"
          ],
          "properties": {
            "deprecated": {
              "const": true
            },
            "validateAllWallMs": {
              "type": "integer",
              "minimum": 1000
            },
            "runtimeSmokeWallMs": {
              "type": "integer",
              "minimum": 1000
            },
            "note": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
