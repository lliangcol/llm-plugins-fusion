{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/lliangcol/llm-plugins-fusion/main/schemas/registry-source.schema.json",
  "title": "Registry Generation Source",
  "description": "Human-maintained source for generating the Claude-compatible marketplace manifest and repository-local marketplace metadata.",
  "type": "object",
  "required": ["name", "owner", "plugins"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "email": { "type": "string", "format": "email" },
        "url": { "type": "string", "format": "uri" }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "description": { "type": "string" }
      }
    },
    "plugins": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["localSource", "distributionSource", "category", "tags", "metadata"],
        "additionalProperties": false,
        "properties": {
          "localSource": {
            "type": "string",
            "minLength": 1,
            "description": "Relative path to the local plugin directory whose .claude-plugin/plugin.json provides plugin-owned fields."
          },
          "distributionSource": { "$ref": "#/$defs/distributionSource" },
          "canarySource": { "$ref": "#/$defs/distributionSource" },
          "category": {
            "type": "string",
            "enum": [
              "development",
              "productivity",
              "review",
              "testing",
              "documentation",
              "devops",
              "security",
              "data",
              "workflow",
              "other"
            ]
          },
          "tags": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "icon": { "type": "string" },
          "screenshots": {
            "type": "array",
            "items": { "type": "string" }
          },
          "checksum": { "type": "string" },
          "metadata": {
            "type": "object",
            "required": [
              "trust-level",
              "risk-level",
              "deprecated",
              "last-updated",
              "maintainer",
              "compatibility",
              "review"
            ],
            "additionalProperties": false,
            "properties": {
              "trust-level": {
                "type": "string",
                "enum": ["official", "author-verified", "community", "experimental"]
              },
              "risk-level": {
                "type": "string",
                "enum": ["low", "medium", "high"]
              },
              "deprecated": { "type": "boolean" },
              "last-updated": { "type": "string", "format": "date" },
              "maintainer": {
                "type": "object",
                "required": ["name"],
                "additionalProperties": false,
                "properties": {
                  "name": { "type": "string", "minLength": 1 },
                  "email": { "type": "string", "format": "email" },
                  "url": { "type": "string", "format": "uri" }
                }
              },
              "compatibility": {
                "type": "object",
                "required": ["commands", "skills", "docs", "validation", "prerequisites"],
                "additionalProperties": false,
                "properties": {
                  "commands": { "type": "string", "minLength": 1 },
                  "skills": { "type": "string", "minLength": 1 },
                  "docs": { "type": "string", "minLength": 1 },
                  "validation": { "type": "string", "minLength": 1 },
                  "prerequisites": { "type": "string", "minLength": 1 }
                }
              },
              "review": {
                "type": "object",
                "required": ["trustPolicy", "securityReview", "releaseHygiene"],
                "additionalProperties": false,
                "properties": {
                  "trustPolicy": { "type": "string", "minLength": 1 },
                  "securityReview": { "type": "string", "minLength": 1 },
                  "releaseHygiene": { "type": "string", "minLength": 1 }
                }
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "distributionSource": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        {
          "type": "object",
          "required": ["source", "url", "path", "ref"],
          "additionalProperties": false,
          "properties": {
            "source": { "const": "git-subdir" },
            "url": { "type": "string", "format": "uri" },
            "path": { "type": "string", "minLength": 1 },
            "ref": { "type": "string", "minLength": 1 },
            "sha": { "type": "string", "pattern": "^[a-f0-9]{40}$" }
          }
        }
      ]
    }
  }
}
