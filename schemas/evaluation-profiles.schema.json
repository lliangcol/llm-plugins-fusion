{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/lliangcol/llm-plugins-fusion/main/schemas/evaluation-profiles.schema.json",
  "type": "object", "additionalProperties": false, "required": ["$schema", "schemaVersion", "profiles"],
  "properties": { "$schema": { "type": "string" }, "schemaVersion": { "const": 1 }, "profiles": { "type": "array", "minItems": 5, "items": { "type": "object", "additionalProperties": false, "required": ["id", "datasetId", "selection", "executionKind", "attempts", "conditions", "assistants"], "properties": {
    "id": { "enum": ["critical", "pr", "nightly", "release", "manual"] }, "datasetId": { "enum": ["critical-live", "live-paired"] },
    "selection": { "type": "object", "additionalProperties": false, "properties": { "all": { "type": "boolean" }, "categories": { "type": "array", "uniqueItems": true, "items": { "type": "string" } } } },
    "executionKind": { "enum": ["plan-only", "simulation", "external-live"] }, "attempts": { "type": "integer", "minimum": 1 },
    "conditions": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } }, "assistants": { "type": "array", "uniqueItems": true, "items": { "type": "string" } }
  } } } }
}
