{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/lliangcol/llm-plugins-fusion/main/schemas/workflow-behaviors.schema.json",
  "title": "Behavior-complete workflow intermediate representation",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "behaviors"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "enum": [1, 2] },
    "behaviors": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/behavior" }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "schemaVersion": { "const": 1 } }, "required": ["schemaVersion"] },
      "then": {
        "properties": {
          "behaviors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "decisionTable": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": { "when": { "$ref": "#/$defs/nonEmptyString" } }
                  }
                }
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "schemaVersion": { "const": 2 } }, "required": ["schemaVersion"] },
      "then": {
        "properties": {
          "behaviors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "decisionTable": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "when": { "$ref": "#/$defs/predicate" },
                      "predicate": false
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "nonEmptyString": { "type": "string", "minLength": 1 },
    "semanticConditionText": { "type": "string", "minLength": 1, "maxLength": 2000, "pattern": "^[^\\u0000-\\u0008\\u000B\\u000C\\u000E-\\u001F\\u007F]*$" },
    "pathPolicy": {
      "type": "object", "additionalProperties": false,
      "required": ["root", "mustExist", "kind", "readable", "writable", "outsideRoot"],
      "properties": {
        "root": { "enum": ["workspace", "artifact-root"] }, "mustExist": { "type": "boolean" },
        "kind": { "enum": ["file", "directory", "either"] }, "readable": { "type": "boolean" },
        "writable": { "type": "boolean" }, "outsideRoot": { "enum": ["deny", "explicit-authorization"] }
      }
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "required", "aliases", "description"],
      "properties": {
        "name": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
        "required": { "type": "boolean" },
        "aliases": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/nonEmptyString" } },
        "description": { "$ref": "#/$defs/nonEmptyString" },
        "default": {},
        "exactValues": { "type": "array", "minItems": 1, "uniqueItems": true },
        "type": { "enum": ["string", "enum", "boolean", "path", "artifact-reference", "review-reference", "approval"] },
        "pathPolicy": { "$ref": "#/$defs/pathPolicy" }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["when", "action"],
      "dependentRequired": {
        "route": ["variantParameters"],
        "variantParameters": ["route"]
      },
      "properties": {
        "when": { "oneOf": [{ "$ref": "#/$defs/nonEmptyString" }, { "$ref": "#/$defs/predicate" }] },
        "predicate": { "$ref": "#/$defs/predicate" },
        "action": { "$ref": "#/$defs/nonEmptyString" },
        "route": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "variantParameters": { "type": "object" }
      }
    },
    "predicate": {
      "oneOf": [
        { "type": "object", "additionalProperties": false, "required": ["op", "condition"], "properties": { "op": { "const": "semantic-condition" }, "condition": { "$ref": "#/$defs/semanticConditionText" } } },
        { "type": "object", "additionalProperties": false, "required": ["op", "args"], "properties": { "op": { "enum": ["all", "any"] }, "args": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/predicate" } } } },
        { "type": "object", "additionalProperties": false, "required": ["op", "arg"], "properties": { "op": { "const": "not" }, "arg": { "$ref": "#/$defs/predicate" } } },
        { "type": "object", "additionalProperties": false, "required": ["op", "input"], "properties": { "op": { "enum": ["input-present", "path-readable", "path-writable"] }, "input": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" } } },
        { "type": "object", "additionalProperties": false, "required": ["op", "input", "value"], "properties": { "op": { "const": "input-equals" }, "input": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" }, "value": {} } },
        { "type": "object", "additionalProperties": false, "required": ["op", "input", "values"], "properties": { "op": { "const": "input-in" }, "input": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" }, "values": { "type": "array", "minItems": 1 } } },
        { "type": "object", "additionalProperties": false, "required": ["op", "capability", "state"], "properties": { "op": { "const": "capability-state" }, "capability": { "type": "string" }, "state": { "type": "string" } } }
      ]
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "action"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "action": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "required", "description"],
      "properties": {
        "name": { "$ref": "#/$defs/nonEmptyString" },
        "required": { "type": "boolean" },
        "description": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "fields", "order", "severityLevels"],
      "properties": {
        "mode": { "enum": ["chat", "artifact", "workspace-and-chat"] },
        "fields": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/field" } },
        "order": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/nonEmptyString" } },
        "severityLevels": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/nonEmptyString" } }
      }
    },
    "deviationPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "instructions"],
      "properties": {
        "mode": { "enum": ["forbid", "report", "approval-required"] },
        "instructions": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "failureOutput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fields", "order"],
      "properties": {
        "fields": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/nonEmptyString" } },
        "order": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/nonEmptyString" } }
      }
    },
    "behavior": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "purpose", "inputs", "decisionTable", "invariants", "stopConditions", "workflowSteps", "deviationPolicy", "output", "validation", "failureOutput"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "purpose": { "$ref": "#/$defs/nonEmptyString" },
        "inputs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/input" } },
        "decisionTable": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/decision" } },
        "invariants": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/nonEmptyString" } },
        "stopConditions": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/nonEmptyString" } },
        "workflowSteps": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/step" } },
        "deviationPolicy": { "$ref": "#/$defs/deviationPolicy" },
        "output": { "$ref": "#/$defs/output" },
        "validation": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/nonEmptyString" } },
        "failureOutput": { "$ref": "#/$defs/failureOutput" },
        "effects": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
      }
    }
  }
}
