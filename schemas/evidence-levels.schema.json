{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/lliangcol/llm-plugins-fusion/main/schemas/evidence-levels.schema.json",
  "title": "Engineering evidence level taxonomy",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schemaVersion", "levels", "sourceControlledStableProof", "dynamicEvidenceStorage", "forbiddenPayloads"],
  "properties": {
    "$schema": { "type": "string", "minLength": 1 },
    "schemaVersion": { "const": 1 },
    "levels": {
      "type": "array",
      "minItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "proves", "doesNotProve"],
        "properties": {
          "id": { "enum": ["E0", "E1", "E2", "E3", "E4", "E5"] },
          "name": { "type": "string", "minLength": 1 },
          "proves": { "type": "string", "minLength": 1 },
          "doesNotProve": { "type": "string", "minLength": 1 }
        }
      }
    },
    "sourceControlledStableProof": {
      "type": "object",
      "additionalProperties": false,
      "required": ["highestAcceptedLevel", "source"],
      "properties": {
        "highestAcceptedLevel": { "enum": ["E0", "E1", "E2", "E3"] },
        "source": { "const": "governance/stable-install-proof.json" }
      }
    },
    "dynamicEvidenceStorage": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "forbiddenPayloads": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
  }
}
