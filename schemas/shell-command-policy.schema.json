{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/lliangcol/llm-plugins-fusion/main/schemas/shell-command-policy.schema.json",
  "title": "Exact project shell command allowlist",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "allowCommands"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "allowCommands": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "argv", "purpose"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "argv": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "purpose": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
