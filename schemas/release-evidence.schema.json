{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/lliangcol/llm-plugins-fusion/main/schemas/release-evidence.schema.json",
  "title": "nova-plugin release evidence",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "generatedAt", "release", "runtime", "tests", "gates", "install", "route", "checksums", "artifacts"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "release": { "type": "object" },
    "runtime": { "type": "object" },
    "tests": { "type": "object" },
    "gates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "status"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "minLength": 1 },
          "durationMs": { "type": "number" },
          "replacementGateId": { "type": "string" }
        }
      }
    },
    "install": { "type": ["object", "null"] },
    "route": { "type": ["object", "null"] },
    "checksums": { "type": "array" },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "sha256"],
        "properties": {
          "path": { "type": "string" },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    }
  }
}
