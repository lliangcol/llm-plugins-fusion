{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/lliangcol/llm-plugins-fusion/main/schemas/diagnostics-report.schema.json",
  "title": "Repository diagnostics report",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "command", "status", "platform", "results"],
  "properties": {
    "schemaVersion": { "enum": [1, 2] },
    "command": { "type": "string", "minLength": 1 },
    "status": { "enum": ["passed", "warn", "skipped", "blocked", "failed"] },
    "platform": { "type": "string", "minLength": 1 },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["elapsedWallMs", "sumTaskMs", "runtimeSmokeMs", "selectedTaskCount", "cacheHitCount", "mode", "profile", "digests"],
      "properties": {
        "elapsedWallMs": { "type": "integer", "minimum": 0 },
        "sumTaskMs": { "type": "integer", "minimum": 0 },
        "runtimeSmokeMs": { "type": "integer", "minimum": 0 },
        "selectedTaskCount": { "type": "integer", "minimum": 0 },
        "cacheHitCount": { "type": "integer", "minimum": 0 },
        "mode": { "enum": ["full", "incremental", "shadow"] },
        "profile": { "type": "object", "additionalProperties": false, "required": ["id", "platform", "arch", "nodeMajor", "runnerClass", "concurrency", "scenario", "comparable"], "properties": {
          "id": { "type": "string" }, "platform": { "enum": ["windows", "linux", "macos"] }, "arch": { "enum": ["x64", "arm64"] }, "nodeMajor": { "type": "integer", "minimum": 22 },
          "runnerClass": { "type": "string" }, "concurrency": { "type": "integer", "minimum": 1 }, "scenario": { "type": "string" }, "comparable": { "type": "boolean" }
        } },
        "digests": { "type": "object", "additionalProperties": false, "required": ["registry", "policy"], "properties": {
          "registry": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }, "policy": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
        } }
      }
    },
    "results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["schemaVersion", "command", "status", "reasonCode", "severity", "platform", "check"],
        "properties": {
          "schemaVersion": { "const": 1 },
          "command": { "type": "string", "minLength": 1 },
          "status": { "enum": ["passed", "warn", "skipped", "blocked", "failed"] },
          "reasonCode": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]+$" },
          "severity": { "enum": ["info", "warning", "error"] },
          "platform": { "type": "string", "minLength": 1 },
          "check": { "type": "string", "minLength": 1 },
          "expected": {},
          "actual": {},
          "remediation": { "type": "string", "minLength": 1 },
          "docsUrl": { "type": "string", "minLength": 1 },
          "evidencePath": { "type": "string", "minLength": 1 },
          "skippedReason": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "schemaVersion": { "const": 2 } }, "required": ["schemaVersion"] },
      "then": { "properties": { "summary": {} }, "required": ["summary"] }
    }
  ]
}
