{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/lliangcol/llm-plugins-fusion/main/schemas/adoption-validation-evidence.schema.json",
  "title": "Public-safe adoption validation evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "evidenceType",
    "recordId",
    "recordBindingSha256",
    "assistant",
    "sourceCommit",
    "sourceDigest",
    "observedAt",
    "validationStatus",
    "sourceVerification",
    "signalResults",
    "privacyReview"
  ],
  "properties": {
    "$schema": { "type": "string", "minLength": 1 },
    "schemaVersion": { "const": 1 },
    "evidenceType": { "const": "adoption-validation" },
    "recordId": { "type": "string", "pattern": "^[A-Z0-9-]+$" },
    "recordBindingSha256": { "$ref": "#/$defs/sha256" },
    "assistant": { "type": "string", "minLength": 1 },
    "sourceCommit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
    "sourceDigest": { "$ref": "#/$defs/sha256" },
    "observedAt": { "type": "string", "format": "date-time" },
    "validationStatus": { "const": "passed" },
    "sourceVerification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "method", "artifactSha256"],
      "properties": {
        "status": { "const": "passed" },
        "method": { "const": "installed-artifact-sha256" },
        "artifactSha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "signalResults": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["signal", "status", "summary"],
        "properties": {
          "signal": { "$ref": "#/$defs/signal" },
          "status": { "const": "passed" },
          "summary": { "type": "string", "minLength": 1, "maxLength": 500 }
        }
      }
    },
    "privacyReview": { "const": "passed" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "signal": {
      "enum": ["installation", "activation", "successful-workflow", "maintenance-commitment"]
    }
  }
}
