{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/lliangcol/llm-plugins-fusion/main/schemas/validation-performance.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "enforcement",
    "minimumStableSamples",
    "maximumSampleAgeDays",
    "externalProvenance",
    "budgetDerivation",
    "profiles",
    "legacyBudgets"
  ],
  "properties": {
    "schemaVersion": { "const": 3 },
    "enforcement": { "const": "profile-required" },
    "minimumStableSamples": { "type": "integer", "minimum": 20 },
    "maximumSampleAgeDays": { "type": "integer", "minimum": 1 },
    "externalProvenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "apiVersion", "requiredForEligibility"],
      "properties": {
        "mode": { "const": "github-actions-api-and-artifact" },
        "apiVersion": { "const": "2026-03-10" },
        "requiredForEligibility": { "const": true }
      }
    },
    "budgetDerivation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "percentileBasisPoints", "headroomBasisPoints", "roundingMs"],
      "properties": {
        "method": { "const": "p95-plus-headroom" },
        "percentileBasisPoints": { "const": 9500 },
        "headroomBasisPoints": { "const": 2500 },
        "roundingMs": { "const": 1000 }
      }
    },
    "profiles": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "platform",
          "arch",
          "nodeMajor",
          "runnerClass",
          "concurrency",
          "scenario",
          "collection",
          "sampleManifest",
          "budgets",
          "owner",
          "reason",
          "regressionRisk"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "platform": { "enum": ["windows", "linux", "macos"] },
          "arch": { "enum": ["x64", "arm64"] },
          "nodeMajor": { "type": "integer", "minimum": 22 },
          "runnerClass": { "type": "string", "minLength": 1 },
          "concurrency": { "type": "integer", "minimum": 1 },
          "scenario": { "enum": ["fresh-process-full-uncached", "full-cache-warm", "incremental-cache-warm"] },
          "collection": {
            "type": "object",
            "additionalProperties": false,
            "required": ["repository", "workflowPath", "workflowRef", "jobName", "artifactName"],
            "properties": {
              "repository": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$" },
              "workflowPath": { "type": "string", "pattern": "^\\.github/workflows/[A-Za-z0-9._-]+\\.ya?ml$" },
              "workflowRef": { "type": "string", "pattern": "^refs/heads/[A-Za-z0-9._/-]+$" },
              "jobName": { "type": "string", "minLength": 1 },
              "artifactName": { "type": "string", "minLength": 1 }
            }
          },
          "sampleManifest": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "canonicalSha256", "aggregateSha256"],
            "properties": {
              "path": { "type": "string", "pattern": "^governance/evidence/[A-Za-z0-9._-]+\\.json$" },
              "canonicalSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
              "aggregateSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
            }
          },
          "budgets": {
            "type": ["object", "null"],
            "additionalProperties": false,
            "required": ["elapsedWallMs", "runtimeSmokeMs"],
            "properties": {
              "elapsedWallMs": { "type": "integer", "minimum": 1000 },
              "runtimeSmokeMs": { "type": "integer", "minimum": 1000 }
            }
          },
          "owner": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 },
          "regressionRisk": { "type": "string", "minLength": 1 }
        }
      }
    },
    "legacyBudgets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["deprecated", "validateAllWallMs", "runtimeSmokeWallMs", "note"],
      "properties": {
        "deprecated": { "const": true },
        "validateAllWallMs": { "type": "integer", "minimum": 1000 },
        "runtimeSmokeWallMs": { "type": "integer", "minimum": 1000 },
        "note": { "type": "string", "minLength": 1 }
      }
    }
  }
}
