{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/lliangcol/llm-plugins-fusion/main/schemas/docs-migrations.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schemaVersion", "retirementPolicy", "mappings"],
  "properties": {
    "$schema": { "type": "string", "minLength": 1 },
    "schemaVersion": { "const": 1 },
    "retirementPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requiredChecks"],
      "properties": {
        "requiredChecks": {
          "const": ["zero-repository-inbound-links", "public-url-audit", "maintainer-approval"]
        }
      }
    },
    "mappings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["from", "to", "disposition", "retireAfterVersion"],
        "properties": {
          "from": { "type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[^\\u0000]+$" },
          "to": { "type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[^\\u0000]+$" },
          "disposition": { "enum": ["retain", "move-with-stub", "merge-with-stub", "generated"] },
          "retireAfterVersion": {
            "type": "string",
            "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[A-Za-z-][0-9A-Za-z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[A-Za-z-][0-9A-Za-z-]*))*))?(?:\\+([0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*))?$"
          }
        }
      }
    }
  }
}
