{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/lliangcol/llm-plugins-fusion/main/schemas/docs-migrations.schema.json",
  "type": "object", "additionalProperties": false,
  "required": ["$schema", "schemaVersion", "mappings"],
  "properties": {
    "$schema": { "type": "string" }, "schemaVersion": { "const": 1 },
    "mappings": { "type": "array", "items": { "type": "object", "additionalProperties": false, "required": ["from", "to", "disposition"], "properties": { "from": { "type": "string" }, "to": { "type": "string" }, "disposition": { "enum": ["retain", "move-with-stub", "merge-with-stub", "generated"] } } } }
  }
}
