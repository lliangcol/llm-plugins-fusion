{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/lliangcol/llm-plugins-fusion/main/schemas/task-registry.schema.json",
  "title": "Maintainer Task Registry",
  "type": "object",
  "required": ["schemaVersion", "categories", "scriptRules", "npmScriptRules", "generatedOutputs"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "categories": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "type": "string", "minLength": 1 }
    },
    "scriptRules": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/rule" }
    },
    "npmScriptRules": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/rule" }
    },
    "generatedOutputs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^docs/" }
    }
  },
  "$defs": {
    "rule": {
      "type": "object",
      "required": ["pattern", "category"],
      "additionalProperties": false,
      "properties": {
        "pattern": { "type": "string", "minLength": 1 },
        "category": { "type": "string", "minLength": 1 }
      }
    }
  }
}
