{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/lliangcol/llm-plugins-fusion/main/schemas/adoption-evidence.schema.json",
  "title": "Privacy-preserving Adoption Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schemaVersion", "status", "records", "minimumForDemonstrated", "collectionPolicy", "claimBoundary"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 2 },
    "status": { "enum": ["not-demonstrated", "demonstrated"] },
    "minimumForDemonstrated": { "type": "integer", "minimum": 2 },
    "claimBoundary": { "type": "string", "minLength": 1 },
    "collectionPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["consentRequired", "rawPrivateDataAllowed", "retentionDays", "withdrawalMechanism", "allowedSignals"],
      "properties": {
        "consentRequired": { "const": true },
        "rawPrivateDataAllowed": { "const": false },
        "retentionDays": { "type": "integer", "minimum": 1, "maximum": 730 },
        "withdrawalMechanism": { "type": "string", "minLength": 1 },
        "allowedSignals": { "type": "array", "minItems": 4, "uniqueItems": true, "items": { "enum": ["installation", "activation", "successful-workflow", "maintenance-commitment"] } }
      }
    },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["recordId", "consumerClass", "assistant", "signals", "sourceDigest", "validationEvidence", "consentEvidence", "privacyReview", "observedAt", "expiresAt"],
        "properties": {
          "recordId": { "type": "string", "pattern": "^[A-Z0-9-]+$" },
          "consumerClass": { "type": "string", "minLength": 1 },
          "assistant": { "type": "string", "minLength": 1 },
          "signals": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "enum": ["installation", "activation", "successful-workflow", "maintenance-commitment"] } },
          "sourceDigest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "validationEvidence": { "type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$" },
          "consentEvidence": { "type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$" },
          "privacyReview": { "const": "passed" },
          "observedAt": { "type": "string", "format": "date-time" },
          "expiresAt": { "type": "string", "format": "date-time" }
        }
      }
    }
  },
  "allOf": [{
    "if": { "properties": { "status": { "const": "demonstrated" } }, "required": ["status"] },
    "then": { "properties": { "records": { "type": "array", "minItems": 2 } } }
  }]
}
