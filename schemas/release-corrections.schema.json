{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/lliangcol/llm-plugins-fusion/main/schemas/release-corrections.schema.json",
  "title": "Release Contract Corrections",
  "type": "object",
  "required": ["schemaVersion", "corrections"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "corrections": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "required": ["id", "issue", "status", "affectedCommits", "stableRelease", "decision", "releaseBoundary"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[A-Z0-9-]+$" },
          "issue": { "type": "integer", "minimum": 1 },
          "status": { "enum": ["active-release-hold", "resolved-by-governed-release"] },
          "affectedCommits": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "pattern": "^[a-f0-9]{40}$" }
          },
          "stableRelease": {
            "type": "object",
            "required": ["tag", "commit", "state"],
            "additionalProperties": false,
            "properties": {
              "tag": { "type": "string", "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$" },
              "commit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
              "state": { "const": "INSTALL_PROVEN" }
            }
          },
          "decision": {
            "type": "object",
            "required": ["authorizedByIssue", "nonRetroactive", "summary"],
            "additionalProperties": false,
            "properties": {
              "authorizedByIssue": { "type": "integer", "minimum": 1 },
              "nonRetroactive": { "const": true },
              "summary": { "type": "string", "minLength": 1 }
            }
          },
          "releaseBoundary": {
            "type": "object",
            "required": ["mayPublishStable", "requiresNewCandidate", "requiresCurrentIndependentReview", "requiresProtectedPublicationEvidence", "requiresInstallProof"],
            "additionalProperties": false,
            "properties": {
              "mayPublishStable": { "const": false },
              "requiresNewCandidate": { "const": true },
              "requiresCurrentIndependentReview": { "const": true },
              "requiresProtectedPublicationEvidence": { "const": true },
              "requiresInstallProof": { "const": true }
            }
          }
        }
      }
    }
  }
}
