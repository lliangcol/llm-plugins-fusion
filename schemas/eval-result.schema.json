{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/lliangcol/llm-plugins-fusion/main/schemas/eval-result.schema.json",
  "title": "Workflow evaluation result",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "layer", "executionMode", "workflowSpecSha256", "cases", "summary", "claimBoundary"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "layer": { "enum": ["static-contract", "adapter-simulation", "live-assistant"] },
    "executionMode": { "type": "string" },
    "workflowSpecSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "sourceDigests": { "type": "object" },
    "baseCommit": { "type": "string" },
    "sourceState": { "type": "string" },
    "releaseTag": { "type": ["string", "null"] },
    "assistant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "executable", "adapterSha256", "adapterLoaded"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "executable": { "type": "string", "minLength": 1 },
        "adapterSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "adapterLoaded": { "type": "boolean" }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["adapterLoadProof", "sandboxProfile", "toolPolicy", "environmentIsolation", "runnerSha256", "datasetSha256"],
      "properties": {
        "adapterLoadProof": { "type": ["string", "null"] },
        "sandboxProfile": { "type": "string" },
        "toolPolicy": { "type": "string" },
        "environmentIsolation": { "type": "string" },
        "runnerSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "datasetSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "startedAt": { "type": "string" },
    "completedAt": { "type": "string" },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          { "type": "object", "required": ["id", "passed"] },
          { "type": "object", "required": ["caseId", "attempt", "contractValid", "zeroProjectWrites"] }
        ]
      }
    },
    "summary": {
      "type": "object",
      "required": ["total", "passed"],
      "properties": {
        "total": { "type": "integer", "minimum": 1 },
        "passed": { "type": "integer", "minimum": 0 }
      }
    },
    "claimBoundary": { "type": "string", "minLength": 1 }
  }
}
