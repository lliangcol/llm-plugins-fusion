{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/lliangcol/llm-plugins-fusion/main/schemas/eval-result.schema.json",
  "title": "Workflow evaluation result",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "layer", "executionMode", "workflowSpecSha256", "cases", "summary", "claimBoundary"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "layer": { "enum": ["static-contract", "adapter-simulation", "live-assistant"] },
    "executionMode": { "type": "string" },
    "workflowSpecSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "sourceDigests": { "type": "object", "additionalProperties": { "type": "string", "pattern": "^[a-f0-9]{64}$" } },
    "baseCommit": { "type": "string" },
    "sourceState": { "type": "string" },
    "releaseTag": { "type": ["string", "null"] },
    "condition": { "enum": ["plugin-enabled", "plugin-disabled"] },
    "profile": { "enum": ["critical", "full"] },
    "assistant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "executable", "adapterSha256", "adapterStaged", "adapterLoadObserved"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "executable": { "type": "string", "minLength": 1 },
        "adapterSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "adapterStaged": { "type": "boolean" },
        "adapterLoadObserved": { "enum": ["observed", "unavailable", "not-applicable"] }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["adapterLoadPolicy", "sandboxProfile", "toolPolicy", "environmentIsolation", "executableResolution", "invocationTimeoutMs", "maxTotalRuntimeMs", "runnerSha256", "datasetSha256"],
      "properties": {
        "adapterLoadPolicy": { "type": "string", "minLength": 1 },
        "sandboxProfile": { "type": "string" },
        "toolPolicy": { "type": "string" },
        "environmentIsolation": { "type": "string" },
        "executableResolution": { "enum": ["direct", "windows-exe", "windows-exe-shim", "windows-volta-shim", "windows-node-shim"] },
        "invocationTimeoutMs": { "type": "integer", "minimum": 1, "maximum": 240000 },
        "maxTotalRuntimeMs": { "type": "integer", "minimum": 1, "maximum": 900000 },
        "runnerSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "datasetSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "startedAt": { "type": "string", "format": "date-time" },
    "completedAt": { "type": "string", "format": "date-time" },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "inventedSurface", "mappingValid", "inputsValid", "passed"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "inventedSurface": { "type": "array", "items": { "type": "string" } },
              "mappingValid": { "type": "boolean" },
              "inputsValid": { "type": "boolean" },
              "passed": { "type": "boolean" }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "expectedDecision", "decision", "reasons", "passed"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "expectedDecision": { "type": "string", "minLength": 1 },
              "decision": { "type": "string", "minLength": 1 },
              "reasons": { "type": "array", "items": { "type": "string" } },
              "passed": { "type": "boolean" }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["caseId", "attempt", "processExit", "processFailure", "timedOut", "latencyMs", "projectDigestBefore", "projectDigestAfter", "zeroProjectWrites", "adapterStaged", "adapterLoadObserved", "adapterLoadReasonCode", "adapterLoadSignals", "observedTools", "allowedReadOnlyTools", "dangerousTools", "deniedDangerousTools", "unknownTools", "deniedUnknownTools", "selectedRoute", "requiredInputs", "routeValid", "top2RouteValid", "requiredInputsValid", "approvalValid", "shapeValid", "inventedSurfaces", "contractValid", "usageStatus", "usageReasonCode", "inputTokens", "outputTokens", "totalTokens", "costUsd", "responseSummary", "parseFailure", "rawOutputSha256", "rawErrorSha256", "rawOutputBytes", "rawErrorBytes", "rawArtifactsRemoved"],
            "properties": {
              "caseId": { "type": "string", "minLength": 1 },
              "kind": { "type": "string" },
              "approvalExpected": { "type": "boolean" },
              "attempt": { "type": "integer", "minimum": 1 },
              "processExit": { "type": ["integer", "null"] },
              "processFailure": { "type": ["string", "null"], "enum": [null, "timeout", "total-timeout", "rate-limit", "authentication", "nonzero-exit"] },
              "timedOut": { "type": "boolean" },
              "latencyMs": { "type": "number", "minimum": 0 },
              "projectDigestBefore": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
              "projectDigestAfter": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
              "zeroProjectWrites": { "type": "boolean" },
              "adapterStaged": { "type": "boolean" },
              "adapterLoadObserved": { "enum": ["observed", "unavailable", "not-applicable"] },
              "adapterLoadReasonCode": { "enum": ["plugin-disabled", "adapter-not-staged", "claude-skill-observed", "claude-skill-not-observed", "codex-load-event-unavailable"] },
              "adapterLoadSignals": { "type": "array", "uniqueItems": true, "items": { "type": "string" } },
              "observedTools": { "type": "array", "uniqueItems": true, "items": { "type": "string" } },
              "allowedReadOnlyTools": { "type": "array", "uniqueItems": true, "items": { "type": "string" } },
              "dangerousTools": { "type": "array", "uniqueItems": true, "items": { "type": "string" } },
              "deniedDangerousTools": { "type": "array", "uniqueItems": true, "items": { "type": "string" } },
              "unknownTools": { "type": "array", "uniqueItems": true, "items": { "type": "string" } },
              "deniedUnknownTools": { "type": "array", "uniqueItems": true, "items": { "type": "string" } },
              "selectedRoute": { "type": "array", "items": { "type": "string" } },
              "requiredInputs": { "type": "array", "items": { "type": "string" } },
              "routeValid": { "type": "boolean" },
              "top2RouteValid": { "type": "boolean" },
              "requiredInputsValid": { "type": "boolean" },
              "approvalValid": { "type": "boolean" },
              "shapeValid": { "type": "boolean" },
              "inventedSurfaces": { "type": "array", "items": { "type": "string" } },
              "contractValid": { "type": "boolean" },
              "responseSummary": { "type": "string", "minLength": 1 },
              "parseFailure": { "type": ["string", "null"], "enum": [null, "missing-output", "invalid-json", "invalid-response"] },
              "rawOutputSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
              "rawErrorSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
              "rawOutputBytes": { "type": "integer", "minimum": 0 },
              "rawErrorBytes": { "type": "integer", "minimum": 0 },
              "rawArtifactsRemoved": { "const": true },
              "usageStatus": { "enum": ["reported", "unavailable"] },
              "usageReasonCode": { "enum": ["cli-reported-usage", "cli-usage-unavailable"] },
              "inputTokens": { "type": ["integer", "null"], "minimum": 0 }
              ,"outputTokens": { "type": ["integer", "null"], "minimum": 0 }
              ,"totalTokens": { "type": ["integer", "null"], "minimum": 0 }
              ,"costUsd": { "type": ["number", "null"], "minimum": 0 }
            }
          }
        ]
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total", "passed"],
      "properties": {
        "total": { "type": "integer", "minimum": 1 },
        "passed": { "type": "integer", "minimum": 0 },
        "inventedSurfaceRate": { "type": "number", "minimum": 0 },
        "mappingValidity": { "type": "number", "minimum": 0 },
        "inputContractValidity": { "type": "number", "minimum": 0 },
        "fallbackCases": { "type": "integer", "minimum": 0 },
        "unsafeContinuation": { "type": "integer", "minimum": 0 },
        "attemptsPerCase": { "type": "integer", "minimum": 1 },
        "uniqueCases": { "type": "integer", "minimum": 1 },
        "unexpectedWrites": { "type": "integer", "minimum": 0 },
        "unsafeToolUse": { "type": "integer", "minimum": 0 },
        "deniedDangerousTools": { "type": "integer", "minimum": 0 },
        "deniedUnknownTools": { "type": "integer", "minimum": 0 },
        "inventedSurfaces": { "type": "integer", "minimum": 0 },
        "adapterStagingFailures": { "type": "integer", "minimum": 0 },
        "adapterLoadObserved": { "type": "integer", "minimum": 0 },
        "adapterLoadUnavailable": { "type": "integer", "minimum": 0 },
        "rawArtifactCleanupFailures": { "type": "integer", "minimum": 0 }
      }
    },
    "claimBoundary": { "type": "string", "minLength": 1 }
  }
}
