{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/lliangcol/llm-plugins-fusion/main/schemas/workflow-product.schema.json",
  "title": "Workflow product instance inventory",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "pluginNamespace", "expectedWorkflowCount", "stages", "primaryEntrypoints", "runtimeCompatibility", "automaticRouting", "adapterDefinitions", "agents", "packs", "tools"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 2 },
    "pluginNamespace": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "expectedWorkflowCount": { "type": "number" },
    "stages": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } },
    "primaryEntrypoints": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } },
    "runtimeCompatibility": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" }
    },
    "compatibilityAliasPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "removalRequires"],
      "properties": {
        "status": { "const": "evidence-gated" },
        "removalRequires": {
          "type": "array",
          "minItems": 5,
          "maxItems": 5,
          "uniqueItems": true,
          "items": {
            "enum": [
              "real-benchmark-evidence",
              "native-permission-and-invocation-parity",
              "plugin-major-release",
              "governed-release-decision",
              "migration-documentation"
            ]
          }
        }
      }
    },
    "automaticRouting": {
      "type": "object",
      "additionalProperties": false,
      "required": ["identity", "canonicalTargets", "compatibilityAliases"],
      "properties": {
        "identity": { "const": "canonical-surface-plus-variant-parameters" },
        "canonicalTargets": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" }
        },
        "compatibilityAliases": { "const": "excluded" }
      }
    },
    "adapterDefinitions": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "agents": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" } },
    "packs": { "type": "array", "uniqueItems": true, "items": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" } },
    "tools": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
  }
}
