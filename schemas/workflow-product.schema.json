{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/lliangcol/llm-plugins-fusion/main/schemas/workflow-product.schema.json",
  "title": "Workflow product instance inventory",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "pluginNamespace", "expectedWorkflowCount", "agents", "packs", "tools"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "pluginNamespace": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "expectedWorkflowCount": { "type": "number" },
    "agents": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } },
    "packs": { "type": "array", "uniqueItems": true, "items": { "type": "string" } },
    "tools": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } }
  }
}
