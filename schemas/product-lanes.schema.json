{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/lliangcol/llm-plugins-fusion/main/schemas/product-lanes.schema.json",
  "title": "Product lane decisions",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "updatedAt", "lanes"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "updatedAt": { "type": "string", "format": "date" },
    "lanes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status", "summary"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "status": { "enum": ["active", "planned", "deferred", "retired"] },
          "summary": { "type": "string", "minLength": 20 }
        }
      }
    }
  }
}
