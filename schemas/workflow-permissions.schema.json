{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/lliangcol/llm-plugins-fusion/main/schemas/workflow-permissions.schema.json",
  "title": "Compiled workflow requirement and permission contracts",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "pluginNamespace", "knownGoodClaudeCli", "primaryEntrypoints", "toolVocabulary", "expectedInventory", "workflows"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 2 },
    "pluginNamespace": { "type": "string" },
    "knownGoodClaudeCli": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "primaryEntrypoints": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } },
    "toolVocabulary": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } },
    "expectedInventory": {
      "type": "object",
      "additionalProperties": false,
      "required": ["combinedSkillCount", "commandIds", "skillNames"],
      "properties": {
        "combinedSkillCount": { "type": "number" },
        "commandIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } },
        "skillNames": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } }
      }
    },
    "workflows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "destructiveActions", "modelInvocable", "subagentSafe", "allowedTools", "disallowedTools", "runtimeRequirements", "permissionPolicy", "enforcement", "legacyCapabilities"],
        "properties": {
          "id": { "type": "string" },
          "destructiveActions": { "enum": ["none", "low", "medium", "high"] },
          "modelInvocable": { "type": "boolean" },
          "subagentSafe": { "type": "boolean" },
          "allowedTools": { "type": "array", "uniqueItems": true, "items": { "type": "string" } },
          "disallowedTools": { "type": "array", "uniqueItems": true, "items": { "type": "string" } },
          "runtimeRequirements": { "type": "object" },
          "permissionPolicy": { "type": "object" },
          "enforcement": { "type": "object" },
          "legacyCapabilities": { "type": "object" },
          "compatibility": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
