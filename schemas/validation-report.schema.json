{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/lliangcol/llm-plugins-fusion/main/schemas/validation-report.schema.json",
  "title": "LLM Plugins Fusion validation report",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "runId", "generatedAt", "failed", "skipped", "gates"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "runId": { "type": "string", "minLength": 1 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "failed": { "type": "integer", "minimum": 0 },
    "skipped": { "type": "integer", "minimum": 0 },
    "gates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "status", "durationMs"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$" },
          "label": { "type": "string", "minLength": 1 },
          "status": { "enum": ["passed", "failed", "skipped", "blocked", "not_applicable"] },
          "durationMs": { "type": "number", "minimum": 0 },
          "reasonCode": { "type": "string" },
          "replacementGateId": { "type": "string" }
        }
      }
    }
  }
}
