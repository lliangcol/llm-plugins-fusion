{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": [
              "-p",
              "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/pre-write-check.sh"
            ],
            "timeout": 10,
            "statusMessage": "检查文件写入规范..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": [
              "-p",
              "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/pre-bash-check.sh"
            ],
            "timeout": 10,
            "statusMessage": "通过默认拒绝的校验命令 broker 检查 shell 命令..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": [
              "-p",
              "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/trusted-node-hook.sh",
              "post-write-verify"
            ],
            "timeout": 10,
            "statusMessage": "复验实际写入路径与受保护配置..."
          }
        ]
      },
      {
        "matcher": "Write|Edit|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": [
              "-p",
              "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/trusted-node-hook.sh",
              "post-audit-log"
            ],
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Write|Edit|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": [
              "-p",
              "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/trusted-node-hook.sh",
              "post-audit-log"
            ],
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "PermissionDenied": [
      {
        "matcher": "Write|Edit|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": [
              "-p",
              "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/trusted-node-hook.sh",
              "post-audit-log"
            ],
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "matcher": "project_settings|local_settings",
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": [
              "-p",
              "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/trusted-node-hook.sh",
              "config-change-guard"
            ],
            "timeout": 10,
            "statusMessage": "冻结会话中的 project/local settings 变更..."
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": [
              "-p",
              "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/trusted-node-hook.sh",
              "audit-compactor"
            ],
            "timeout": 10
          }
        ]
      }
    ]
  }
}
