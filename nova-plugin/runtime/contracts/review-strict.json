  "behaviorContract": {
    "schemaVersion": 2,
    "source": "workflow-specs/behaviors.v2.json",
    "guidanceReference": "../../skills/nova-review/SKILL.md",
    "conflictPolicy": "fail-closed",
    "purpose": "Perform exhaustive production-critical review with explicit failure-cost reasoning and no implementation.",
    "inputs": [
      {
        "name": "REVIEW_SCOPE",
        "required": true,
        "aliases": [
          "INPUT",
          "SCOPE"
        ],
        "description": "High-risk modules, stateful logic, or refactors to audit."
      }
    ],
    "decisionTable": [
      {
        "when": {
          "op": "all",
          "args": [
            {
              "op": "input-present",
              "input": "REVIEW_SCOPE"
            }
          ]
        },
        "action": "Classify it Critical."
      },
      {
        "when": {
          "op": "all",
          "args": [
            {
              "op": "input-present",
              "input": "REVIEW_SCOPE"
            }
          ]
        },
        "action": "Classify it Major."
      },
      {
        "when": {
          "op": "all",
          "args": [
            {
              "op": "input-present",
              "input": "REVIEW_SCOPE"
            }
          ]
        },
        "action": "Classify it Minor."
      }
    ],
    "invariants": [
      "Do not write code or implementation-level fixes.",
      "Make assumptions explicit.",
      "Justify the risk or cost of every finding.",
      "Do not approve or decide release readiness."
    ],
    "stopConditions": [
      "REVIEW_SCOPE is unresolved.",
      "Required evidence for a high-confidence conclusion is unavailable.",
      "The request requires implementation."
    ],
    "workflowSteps": [
      {
        "id": "inspect",
        "action": "Inspect correctness, edge cases, concurrency, performance, errors, observability, tests, boundaries, maintainability, and evolution risk."
      },
      {
        "id": "model-failure-cost",
        "action": "Explain realistic failure impact and uncertainty."
      },
      {
        "id": "classify",
        "action": "Classify each supported finding by severity."
      },
      {
        "id": "emit",
        "action": "Provide issue, risk or cost, and conceptual guidance."
      }
    ],
    "deviationPolicy": {
      "mode": "forbid",
      "instructions": "Do not redesign end-to-end, implement fixes, or broaden REVIEW_SCOPE."
    },
    "output": {
      "mode": "chat",
      "fields": [
        {
          "name": "Critical",
          "required": true,
          "description": "Catastrophic or core-behavior risks."
        },
        {
          "name": "Major",
          "required": true,
          "description": "Material realistic risks and costs."
        },
        {
          "name": "Minor",
          "required": true,
          "description": "Low-risk quality gaps."
        }
      ],
      "order": [
        "Critical",
        "Major",
        "Minor"
      ],
      "severityLevels": [
        "Critical",
        "Major",
        "Minor"
      ]
    },
    "validation": [
      "Confirm every finding includes evidence, impact, and conceptual direction.",
      "Confirm severity follows the decision table.",
      "Confirm assumptions are labeled and no implementation appears."
    ],
    "failureOutput": {
      "fields": [
        "status",
        "missing evidence",
        "reviewed scope",
        "safe next action"
      ],
      "order": [
        "status",
        "missing evidence",
        "reviewed scope",
        "safe next action"
      ]
    },
    "effects": []
  },
  "claimBoundary": "Behavior-complete machine-readable contract generated from the canonical behavior IR; the Skill contains the same generated contract plus explanatory authored guidance."
