  "behaviorContract": {
    "schemaVersion": 2,
    "source": "workflow-specs/behaviors.v2.json",
    "guidanceReference": "../../skills/nova-review/SKILL.md",
    "conflictPolicy": "fail-closed",
    "purpose": "Verify known findings from an existing Codex review without doing new implementation.",
    "inputs": [
      {
        "name": "REVIEW_FILE",
        "type": "review-reference",
        "pathPolicy": {
          "root": "workspace",
          "mustExist": true,
          "kind": "file",
          "readable": true,
          "writable": false,
          "outsideRoot": "deny"
        },
        "required": true,
        "aliases": [
          "REVIEW_PATH"
        ],
        "description": "Existing review.md to verify."
      },
      {
        "name": "CHECKS_FILE",
        "type": "artifact-reference",
        "pathPolicy": {
          "root": "workspace",
          "mustExist": true,
          "kind": "file",
          "readable": true,
          "writable": false,
          "outsideRoot": "deny"
        },
        "required": false,
        "aliases": [
          "CHECKS_PATH"
        ],
        "description": "Optional local checks evidence."
      },
      {
        "name": "BASE",
        "required": false,
        "aliases": [
          "BASE_BRANCH"
        ],
        "description": "Optional comparison base."
      }
    ],
    "decisionTable": [
      {
        "when": {
          "op": "input-present",
          "input": "CHECKS_FILE"
        },
        "action": "Use it as supporting evidence while independently verifying review items."
      },
      {
        "when": {
          "op": "not",
          "arg": {
            "op": "input-present",
            "input": "CHECKS_FILE"
          }
        },
        "action": "Mark local-check conclusions unavailable instead of inferring them."
      }
    ],
    "invariants": [
      "Do not modify project code.",
      "Focus on findings in REVIEW_FILE.",
      "Report new high-risk issues only when confidence is high."
    ],
    "stopConditions": [
      "REVIEW_FILE is missing, unreadable, or outside approved scope.",
      "Required external verification capability is unavailable or denied.",
      "Verification would require implementation changes."
    ],
    "workflowSteps": [
      {
        "id": "load-review",
        "action": "Validate and read REVIEW_FILE plus optional checks evidence."
      },
      {
        "id": "run-verify",
        "action": "Run the bundled verify script against current changes."
      },
      {
        "id": "retain-evidence",
        "action": "Retain verify.md and runtime evidence."
      },
      {
        "id": "summarize",
        "action": "Report resolved, unresolved, uncertain, and new high-risk findings."
      }
    ],
    "deviationPolicy": {
      "mode": "forbid",
      "instructions": "Do not reopen the task as an unbounded review or implementation run."
    },
    "output": {
      "mode": "artifact",
      "fields": [
        {
          "name": "verification artifact",
          "required": true,
          "description": "Structured verify.md."
        },
        {
          "name": "runtime evidence",
          "required": true,
          "description": "Actual verifier environment."
        },
        {
          "name": "merge recommendation",
          "required": true,
          "description": "Evidence-bounded recommendation."
        }
      ],
      "order": [
        "verification artifact",
        "runtime evidence",
        "merge recommendation"
      ],
      "severityLevels": [
        "resolved",
        "unresolved",
        "uncertain",
        "new-high-risk"
      ]
    },
    "validation": [
      "Confirm verification references REVIEW_FILE.",
      "Confirm no project code changed.",
      "Confirm unavailable checks are explicitly marked unavailable."
    ],
    "failureOutput": {
      "fields": [
        "status",
        "blocker",
        "review file",
        "safe next action"
      ],
      "order": [
        "status",
        "blocker",
        "review file",
        "safe next action"
      ]
    },
    "effects": []
  },
  "claimBoundary": "Behavior-complete machine-readable contract generated from the canonical behavior IR. Workflow-level effects are authoritative; behaviorContract.effects declares the validated empty subset and cannot expand workflow capability scope. The referenced authored guidance surface may add explanatory context but cannot override this contract."
